# ─── Supabase ────────────────────────────────────────────────────────────────
# Get from: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...

# Server-only: never expose to client (no NEXT_PUBLIC_ prefix)
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...

# ─── Encryption ──────────────────────────────────────────────────────────────
# AES-256-GCM key for encrypting user API keys in the database
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-hex-char-string-here

# ─── Trigger.dev ─────────────────────────────────────────────────────────────
# Get from: https://cloud.trigger.dev → Project Settings
TRIGGER_SECRET_KEY=tr_dev_your-secret-key
TRIGGER_PROJECT_ID=proj_your-project-id

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
